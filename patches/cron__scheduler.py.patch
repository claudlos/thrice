+_STALE_RUNNING_THRESHOLD_SECONDS = 600  # 10 minutes
+
+
+def _recover_stale_running_jobs() -> None:
+    """Detect and recover jobs stuck in 'running' state from a previous crash.
+
+    Only recovers jobs that have been running for longer than
+    _STALE_RUNNING_THRESHOLD_SECONDS (default 10 minutes) to avoid
+    marking legitimately-running jobs as failed.
+    """
+    from cron.jobs import load_jobs, save_jobs
+    import time as _time
+    from datetime import datetime, timezone
+    jobs = load_jobs()
+    recovered = 0
+    now = _time.time()
+    for job in jobs:
+        if job.get("state") == "running":
+            # Check if the job has been running long enough to be considered stale
+            last_run = job.get("last_run_at") or job.get("running_since")
+            if last_run:
+                try:
+                    if isinstance(last_run, str):
+                        # Parse ISO format string
+                        run_dt = datetime.fromisoformat(last_run)
+                        if run_dt.tzinfo is None:
+                            run_dt = run_dt.replace(tzinfo=timezone.utc)
+                    else:
+                        run_dt = last_run
+                    elapsed = now - run_dt.timestamp()
+                except Exception:
+                    elapsed = _STALE_RUNNING_THRESHOLD_SECONDS + 1  # assume stale on parse error
+            else:
+                # No timestamp available — assume stale (legacy job)
+                elapsed = _STALE_RUNNING_THRESHOLD_SECONDS + 1
+
+            if elapsed < _STALE_RUNNING_THRESHOLD_SECONDS:
+                logger.debug(
+                    "Job '%s' (ID: %s) still running for %.0fs — not yet stale",
+                    job.get("name", "?"), job.get("id", "?"), elapsed
+                )
+                continue
+
+            logger.warning(
+                "Recovering stale running job '%s' (ID: %s) — marking as failed (running for %.0fs)",
+                job.get("name", "?"), job.get("id", "?"), elapsed
+            )
+            # Guard: running -> failed is a valid transition
+            _guard_transition(job.get("id", "?"), "running", "failed")
+            job["state"] = "failed"
+            job["last_error"] = "Process crashed during execution (recovered on restart)"
+            job["last_status"] = "error"
+            recovered += 1
+    if recovered:
+        save_jobs(jobs)
+        logger.info("Recovered %d stale running job(s)", recovered)
+
+
